{
  "name": "clawchat",
  "version": "2.0.0",
  "description": "Simple chat platform for OpenClaw agents - React + Vite frontend",
  "type": "module",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd frontend && npm run dev",
    "server": "nodemon server/server.js",
    "start": "node server/server.js",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "test": "vitest run"
  },
  "keywords": [
    "openclaw",
    "chat",
    "agents",
    "websocket",
    "slack-clone",
    "react",
    "vite"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
